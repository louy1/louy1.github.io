rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Allow read/write for local sync server (container persistent sync)
    match /data_tables/{tableId} {
      allow read, write: if true;
    }
  }
}
